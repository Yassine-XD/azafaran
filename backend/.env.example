# Copy to `.env` and replace every CHANGE_ME_* sentinel before booting.
# The backend refuses to start if required secrets are unset / too short.

NODE_ENV=development
PORT=3000

# Postgres connection string. Do NOT reuse this password in production.
DATABASE_URL=postgresql://postgres:CHANGE_ME_LOCAL_DB_PASSWORD@localhost:5432/carnesalhambra

# JWT signing keys — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use TWO DIFFERENT values. Never commit the real ones.
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS_DIFFERENT_FROM_ACCESS

# Public URL of the mobile/web client (used for password-reset links, etc.).
CLIENT_URL=http://localhost:8081

# Public URL of the admin dashboard.
ADMIN_URL=https://www.azafaran.es/admin

# Comma-separated extra browser origins allowed by CORS.
# List apex + www of the public domain, plus any staging origins.
# CORS_ORIGINS=https://azafaran.es,https://www.azafaran.es

# SMTP / Email (optional — emails disabled if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASS=CHANGE_ME_SMTP_APP_PASSWORD
SMTP_FROM=Azafaran <noreply@azafaran.es>
ADMIN_EMAIL=admin@azafaran.es

# Stripe (optional — payments disabled if not set)
STRIPE_SECRET_KEY=CHANGE_ME_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=CHANGE_ME_STRIPE_WEBHOOK_SECRET

# Expo push notifications (optional)
# Strengthens authentication when sending pushes via the Expo SDK.
# Generate at https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=
