# Expo public env. These are bundled into the client at build time and are
# visible to end users, so NEVER put secrets here. Override for local dev by
# copying this file to `.env` at the frontend/ root.

# Public API host (no trailing slash, no /api/v1 suffix).
# The client appends `/api/v1` itself. Use HTTPS in every non-dev environment.
EXPO_PUBLIC_API_HOST=https://www.azafaran.es
