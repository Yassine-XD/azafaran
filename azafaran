cat <<EOF
${C_BOLD}notif:${C_RESET}  notification debugging
  Auto-targets prod when deploy/.env exists, else local.
  Override: DB_TARGET=local|prod ./azafaran notif:...
  notif:campaigns [N=10]    last N notification_campaigns rows
  notif:log <campaign_id>   per-user delivery rows for that campaign
  notif:tokens [user_id]    active push tokens
  notif:opt-in <user_id>    ⚠ enable 'promotions' for testing
