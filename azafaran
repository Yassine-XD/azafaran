help_mobile() {
cat <<EOF
${C_BOLD}mobile:${C_RESET} Expo / EAS shortcuts
  mobile:start              expo start (Metro)
  mobile:build:dev:{android,ios}     EAS dev-client builds
  mobile:build:prod:{android,ios}    EAS production builds
  mobile:credentials        EAS credentials (FCM v1 / APNs uploads)
EOF
}

show_help() {
cat <<EOF
${C_BOLD}azafaran${C_RESET} — repo-wide ops helper

  Usage: ./azafaran <subcommand> [args]    [-y to skip confirms]
         ./azafaran help <category>        only that category

EOF
  help_dev;    echo
  help_build;  echo
  help_ship;   echo
  help_prod;   echo
  help_db;     echo
  help_notif;  echo
  help_mobile
}

help() {
  case "${1:-}" in
    dev)    help_dev ;;
    build)  help_build ;;
    ship)   help_ship ;;
    prod)   help_prod ;;
    db)     help_db ;;
    notif)  help_notif ;;
    mobile) help_mobile ;;
    "")     show_help ;;
    *)      die "Unknown help category: $1 (try: dev build ship prod db notif mobile)" ;;
  esac
}

# ── Dispatch ────────────────────────────────────────────────────────────────
cmd="${1:-}"
shift || true

case "$cmd" in
  ""|help|-h|--help) help "${1:-}" ;;
  *)
    # Allow only known function names to be called.
    if declare -F "$cmd" >/dev/null; then
      "$cmd" "$@"
    else
      warn "Unknown subcommand: $cmd"
      echo
      show_help
      exit 1
    fi
    ;;
esac
