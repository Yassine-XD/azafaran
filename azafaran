${C_BOLD}prod:${C_RESET}   run on the VPS, inside the repo (e.g. /opt/azafaran)
  prod:up | prod:down       bring the full stack up / down
  prod:status               docker compose ps
  prod:logs <svc> [-n N]    follow logs (api / nginx / postgres / certbot)
  prod:restart <svc>        restart one service
  prod:rebuild [svc=api]    ⚠ rebuild image + recreate container
  prod:reload-nginx         graceful nginx reload (after static rsync)
  prod:exec <svc> <cmd...>  one-off command in a container
  prod:migrate:up|down|status
  prod:psql                 interactive psql
  prod:psql:run "<sql>"     one-shot SQL
  prod:health               curl /api/v1/health
