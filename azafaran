${C_BOLD}dev:${C_RESET}    local development on the laptop
  dev:db:up                 start local Postgres (backend/docker-compose.yml)
  dev:db:down               stop local Postgres
  dev:db:psql               open psql against the local DB
  dev:db:reset              ⚠ wipe + recreate + migrate + seed (asks)
  dev:migrate:up|down|status
  dev:seed                  load backend/seed.sql
  dev:start:{backend,admin,landing,frontend}
  dev:test [pattern]        backend Jest, optionally filter by test name
  dev:typecheck             tsc across all four apps
  dev:lint                  run lint where available
EOF
}
help_build() {
cat <<EOF
${C_BOLD}build:${C_RESET}  produce shippable artifacts on the laptop
  build:admin               admin/dist via Vite
  build:landing             landing/dist via vite-react-ssg + post-build
  build:all                 admin + landing
EOF
}
help_ship() {
cat <<EOF
${C_BOLD}ship:${C_RESET}   stage builds for VPS rsync
  ship:admin                copy admin/dist  → deploy/admin
  ship:landing              copy landing/dist → deploy/landing
  ship:all                  both
  ship:rsync user@host:/opt/azafaran
                            rsync backend/ + deploy/ to the VPS
EOF
