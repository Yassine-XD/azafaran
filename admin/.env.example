# Vite public env. These are bundled into the dashboard at build time and are
# visible to users of the admin SPA, so NEVER put secrets here. Copy to
# `.env.local` (dev) or `.env.production` (prod builds) and override.

# Base URL including /api/v1. Use HTTPS in every non-dev environment.
VITE_API_BASE_URL=https://www.azafaran.es/api/v1
